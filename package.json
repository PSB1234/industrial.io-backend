{
	"name": "backend",
	"version": "0.0.1",
	"description": "A socket server",
	"type": "module",
	"main": "dist/index.js",
	"scripts": {
		"build": "tsc --noEmit && esbuild src/app/index.ts --bundle --platform=node --format=esm --target=node24 --outfile=dist/index.js --alias:@=./src --packages=external",
		"dev": "tsx watch --env-file .env src/app/index.ts",
		"start": "node dist/index.js",
		"format": "biome format --write .",
		"lint": "biome lint .",
		"check": "biome check --write .",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage"
	},
	"license": "UNLICENSED",
	"dependencies": {
		"@neondatabase/serverless": "^1.0.2",
		"@t3-oss/env-core": "^0.13.8",
		"@types/cors": "^2.8.19",
		"cors": "^2.8.5",
		"dotenv": "^17.2.3",
		"drizzle-orm": "^0.45.1",
		"express": "^5.1.0",
		"postgres": "^3.4.8",
		"redis": "^5.11.0",
		"socket.io": "^4.8.1",
		"unique-names-generator": "^4.7.1",
		"zod": "^4.1.13"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.4",
		"@playwright/test": "^1.58.2",
		"@types/express": "^5.0.5",
		"@types/node": "^24.10.1",
		"drizzle-kit": "^0.31.9",
		"esbuild": "^0.27.3",
		"esbuild-register": "^3.6.0",
		"tsx": "^4.20.6",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18"
	}
}
