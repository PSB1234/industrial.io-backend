{
	"name": "backend",
	"version": "0.0.1",
	"description": "A socket server",
	"type": "module",
	"main": "dist/index.js",
	"scripts": {
		"build": "tsc",
		"dev": "tsx watch --env-file .env src/app/index.ts",
		"start": "node dist/index.js",
		"format": "biome format --write .",
		"lint": "biome lint .",
		"check": "biome check --write ."
	},
	"license": "UNLICENSED",
	"dependencies": {
		"@t3-oss/env-core": "^0.13.8",
		"dotenv": "^17.2.3",
		"express": "^5.1.0",
		"socket.io": "^4.8.1",
		"unique-names-generator": "^4.7.1",
		"zod": "^4.1.13"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.8",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.5",
		"@types/node": "^24.10.1",
		"cors": "^2.8.5",
		"tsx": "^4.20.6",
		"typescript": "^5.9.3"
	}
}
