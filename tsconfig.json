{
	"compilerOptions": {
		"esModuleInterop": true,
		"skipLibCheck": true,
		"moduleResolution": "bundler",
		"target": "es2022",
		"allowJs": true,
		"resolveJsonModule": true,
		"moduleDetection": "force",
		"isolatedModules": true,
		"verbatimModuleSyntax": false,
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"noImplicitOverride": true,
		"noEmit": true,
		"module": "ESNext",
		"outDir": "dist",
		"sourceMap": true,
		"lib": ["es2022"],
		"rootDir": "./src",
		"baseUrl": ".",
		"paths": {
			"@/*": ["src/*"]
		}
	},
	"include": ["src/**/*"]
}
